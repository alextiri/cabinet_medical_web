<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.cabinet.client.view.DoctorController"
           style="-fx-background-color: #f4f4f4;">
    <VBox alignment="CENTER"
          spacing="20"
          maxWidth="550"
          style="
                -fx-background-color: white;
                -fx-background-radius: 16;
                -fx-padding: 35;
                -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 20, 0, 0, 4);
          ">
        <Label fx:id="welcomeLabel"
               style="-fx-font-size: 24px; -fx-font-weight: bold;" />
        <Button text="%doctor.schedule"
                onAction="#onAppointmentsClick"
                prefWidth="300"
                prefHeight="45"
                style="
                    -fx-background-color: #5b7c99;
                    -fx-text-fill: white;
                    -fx-font-size: 14px;
                    -fx-font-weight: bold;
                    -fx-background-radius: 8;
                "/>
        <Button text="%doctor.patients"
                onAction="#onPatientsClick"
                prefWidth="300"
                prefHeight="45"
                style="
                    -fx-background-color: #5b7c99;
                    -fx-text-fill: white;
                    -fx-font-size: 14px;
                    -fx-font-weight: bold;
                    -fx-background-radius: 8;
                "/>
        <Button text="%common.logout"
                onAction="#onLogoutClick"
                prefWidth="300"
                prefHeight="40"
                style="
                    -fx-background-color: #b56576;
                    -fx-text-fill: white;
                    -fx-font-size: 14px;
                    -fx-font-weight: bold;
                    -fx-background-radius: 8;
                "/>
    </VBox>
</StackPane>
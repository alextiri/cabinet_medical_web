<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="14"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.cabinet.client.view.ConsultationDialogController"
      prefWidth="500"
      prefHeight="650"
      style="-fx-background-color: white;">

    <padding>
        <Insets top="20"
                right="20"
                bottom="20"
                left="20"/>
    </padding>

    <Label text="Consultation Details"
           style="
                -fx-font-size: 24px;
                -fx-font-weight: bold;
           "/>

    <VBox spacing="6">
        <Label text="Symptoms"/>

        <TextArea fx:id="symptomsArea"
                  prefHeight="100"
                  wrapText="true"/>
    </VBox>

    <VBox spacing="6">
        <Label text="Diagnosis"/>

        <TextArea fx:id="diagnosisArea"
                  prefHeight="100"
                  wrapText="true"/>
    </VBox>

    <VBox spacing="6">
        <Label text="Treatment"/>

        <TextArea fx:id="treatmentArea"
                  prefHeight="100"
                  wrapText="true"/>
    </VBox>

    <VBox spacing="6">
        <Label text="Observations"/>

        <TextArea fx:id="observationsArea"
                  prefHeight="100"
                  wrapText="true"/>

    </VBox>

    <HBox spacing="12"
          alignment="CENTER_RIGHT">

        <Button text="Cancel"
                onAction="#onCancelClick"/>

        <Button text="Save Consultation"
                onAction="#onSaveClick"
                style="
                    -fx-background-color: #22C55E;
                    -fx-text-fill: white;
                    -fx-font-weight: bold;
                "/>
    </HBox>
</VBox>
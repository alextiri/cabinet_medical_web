<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.cabinet.client.view.AdminController"
           style="-fx-background-color: #f4f4f4;">

    <VBox alignment="CENTER"
          spacing="30"
          maxWidth="500"
          maxHeight="450"
          style="-fx-background-color: white;
                 -fx-background-radius: 20;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 20, 0, 0, 5);">

        <padding>
            <Insets top="50"
                    right="50"
                    bottom="50"
                    left="50"/>
        </padding>

        <Label text="%admin.dashboard"
               style="-fx-font-size: 36px;
                      -fx-font-weight: bold;" />

        <Button text="%admin.manage.users"
                prefWidth="320"
                prefHeight="70"
                style="-fx-background-color: #5b88a5;
                       -fx-text-fill: white;
                       -fx-font-size: 22px;
                       -fx-font-weight: bold;
                       -fx-background-radius: 12;"
                onAction="#onManageUsersClick"/>

        <Button text="%common.logout"
                prefWidth="320"
                prefHeight="70"
                style="-fx-background-color: #c25f79;
                       -fx-text-fill: white;
                       -fx-font-size: 22px;
                       -fx-font-weight: bold;
                       -fx-background-radius: 12;"
                onAction="#onLogoutClick"/>

    </VBox>

</StackPane>